APP_ENV=development
LOG_LEVEL=INFO
DRY_RUN=true
RATE_LIMIT_SECONDS=2
WAITLIST_RETRY_DAYS=1
SOUNDEO_MAX_RESULTS=10
SOUNDEO_HEADLESS=true

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8899/callback
SPOTIFY_SCOPE=user-library-read
SPOTIFY_TOKEN_CACHE_PATH=
SPOTIFY_REQUEST_TIMEOUT_SECONDS=30
SPOTIFY_REQUEST_RETRY_COUNT=3
SPOTIFY_REQUEST_RETRY_BACKOFF_SECONDS=2
SPOTIFY_RECENT_DAYS_ON_FIRST_SYNC=7

SOUNDEO_BASE_URL=https://soundeo.com
SOUNDEO_LOGIN_URL=https://soundeo.com
SOUNDEO_SEARCH_URL=https://soundeo.com
SOUNDEO_DOWNLOADS_URL=https://soundeo.com/account/downloads
SOUNDEO_VOTES_URL=https://soundeo.com/account/votes
SOUNDEO_FAVORITES_URL=https://soundeo.com/account/favorites
SOUNDEO_USERNAME=
SOUNDEO_PASSWORD=
